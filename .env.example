# Core
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# Database
POSTGRES_USER=sports
POSTGRES_PASSWORD=sports
POSTGRES_DB=sports
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://sports:sports@postgres:5432/sports

# Redis
REDIS_URL=redis://redis:6379/0

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Data sources (leave every key empty to keep demo mode)
# ------------------------------------------------------
# Football-Data.org (free tier: 10 req/min, top-5 leagues).
# Get a free token at https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=
# Comma-separated competition codes. Free tier: PL, ELC, SA, PD, BL1, FL1,
# DED, PPL, CL, BSA.
FOOTBALL_DATA_COMPETITIONS=PL,SA,BL1,FL1,PD,DED,PPL
# Leave empty to use the current season. Example: 2024 pulls the 2024/25 season.
FOOTBALL_DATA_SEASON=

# Other providers (stubs for now — will be wired in future PRs).
API_FOOTBALL_KEY=
SOFASCORE_ENABLED=false
UNDERSTAT_ENABLED=false
THE_ODDS_API_KEY=
SNAI_ENABLED=false

# Force demo adapter even when credentials are set (handy for CI / local smoke).
FORCE_DEMO_MODE=false

# Scheduler
# When SCHEDULER_ENABLED=true the API process runs a daily ingestion job at
# SCHEDULER_CRON_HOUR:SCHEDULER_CRON_MINUTE UTC across every active source.
SCHEDULER_ENABLED=false
SCHEDULER_CRON_HOUR=3
SCHEDULER_CRON_MINUTE=0

# Value bet engine
VALUE_BET_MIN_EDGE=0.03
VALUE_BET_MIN_CONFIDENCE=0.55
